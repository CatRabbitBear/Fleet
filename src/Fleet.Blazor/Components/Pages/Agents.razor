@page "/agents"
@rendermode InteractiveServer
@inject HttpClient Http
@inject Microsoft.Extensions.Logging.ILogger<Agents> Logger

<h1>Agent Debug</h1>

<p>
    Enter your message below and click <strong>Run Task</strong>. Only a single <em>User</em> message is sent.
</p>

<textarea @bind="UserInput" rows="4" placeholder="Type your message here..." style="width:100%;max-width:600px;"></textarea>
<br />
<button @onclick="RunTaskAsync" style="margin-top:.5rem;padding:.5rem 1rem;">Run Task</button>

<div id="result" style="margin-top:1rem;white-space:pre-wrap;">
    @ResultText
</div>

@code {
    private string UserInput { get; set; } = string.Empty;
    private string ResultText { get; set; } = string.Empty;

    private async Task RunTaskAsync()
    {
        Logger.LogInformation("Agents chatbox submit clicked. Input length: {InputLength}", UserInput?.Length ?? 0);
        Fleet.Blazor.Utilities.ChatDiagnostics.Info($"UI submit initiated. InputLength={UserInput?.Length ?? 0}");
        if (string.IsNullOrWhiteSpace(UserInput))
        {
            ResultText = "Please enter a message first.";
            Fleet.Blazor.Utilities.ChatDiagnostics.Info("UI submit blocked because input is empty.");
            return;
        }

        ResultText = "Running...";
        try
        {
            var payload = new
            {
                history = new[]
                {
                    new { role = "User", content = UserInput }
                }
            };

            var route = "/api/chat-completions/run-task";
            Logger.LogInformation("Posting chat request to {Route}", route);
            Fleet.Blazor.Utilities.ChatDiagnostics.Info($"Posting request to {route}");

            var response = await Http.PostAsJsonAsync(route, payload);
            var rawBody = await response.Content.ReadAsStringAsync();
            Logger.LogInformation("Chat request completed with status {StatusCode}. Body length: {BodyLength}", (int)response.StatusCode, rawBody.Length);
            Fleet.Blazor.Utilities.ChatDiagnostics.Info($"Response status={(int)response.StatusCode}, reason={response.ReasonPhrase}, bodyLength={rawBody.Length}");

            RunTaskResponse? data = null;
            if (!string.IsNullOrWhiteSpace(rawBody))
            {
                data = System.Text.Json.JsonSerializer.Deserialize<RunTaskResponse>(rawBody, new System.Text.Json.JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });
            }

            if (response.IsSuccessStatusCode && data is not null)
            {
                ResultText = data.Result
                    + (string.IsNullOrEmpty(data.FilePath)
                        ? string.Empty
                        : $"\nFile output saved to: {data.FilePath}");
            }
            else
            {
                ResultText = $"Error: {data?.Error ?? response.ReasonPhrase}";
                Fleet.Blazor.Utilities.ChatDiagnostics.Info($"UI displayed error. Status={(int)response.StatusCode}, ParsedError={data?.Error ?? "<null>"}");
            }
        }
        catch (Exception ex)
        {
            ResultText = $"Request failed: {ex.Message}";
            Logger.LogError(ex, "Agents chatbox request failed.");
            Fleet.Blazor.Utilities.ChatDiagnostics.Error("UI request failed.", ex);
        }
    }

    private class RunTaskResponse
    {
        public string Result { get; set; } = "";
        public string? FilePath { get; set; }
        public string? Error { get; set; }
    }
}
